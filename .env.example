# Telegram API credentials
APP_ID=123456
APP_HASH=your_app_hash
BOT_TOKEN=your_bot_token

# Administrator user IDs (comma separated)
OWNER=123456789

# Database DSN (sqlite, mysql, etc.)
DB_DSN=sqlite:///db.sqlite

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Audio format (m4a, mp3, etc.)
AUDIO_FORMAT=mp3

# Maximum file size for Telegram upload (in bytes)
TG_NORMAL_MAX_SIZE=2000000000

# Free downloads per user per day (if using quota)
FREE_DOWNLOAD=3

# Enable ffmpeg processing
ENABLE_FFMPEG=True

# Cookies from browser (optional)
BROWSERS=

# YouTube PO Token (optional)
POTOKEN=your_po_token
